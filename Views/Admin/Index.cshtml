@model IEnumerable<BlindMatchPAS.Models.ProjectProposal>

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-shield-lock-fill me-2"></i>Admin Management Panel</h2>
    <div class="card border-0 shadow-sm">
        <table class="table align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Proposal Title</th>
                    <th>Technologies</th>
                    <th>Match Status</th>
                    <th>Identity Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                <tr>
                    <td>@item.Title</td>
                    <td><span class="badge bg-light text-dark">@item.TechStack</span></td>
                    <td>@(item.IsMatched ? "✅ Matched" : "⏳ Pending")</td>
                    <td>@(item.IsIdentityRevealed ? "🔓 Revealed" : "🔒 Hidden")</td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>