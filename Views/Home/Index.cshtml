@{
    ViewData["Title"] = "Home Page";
}

<div class="container py-5">
    <div class="text-center mb-5 p-5 bg-dark text-white rounded shadow-lg">
        <h1 class="display-4 fw-bold">Welcome to BlindMatch PAS</h1>
        <p class="lead">A Centralized Research Proposal Management System for Blind Evaluations.</p>
        <hr class="my-4 border-light w-25 mx-auto">
        <p>Ensuring fairness and transparency in academic project matching.</p>
    </div>

    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <div class="mb-3 text-primary"><i class="bi bi-mortarboard-fill fs-1"></i></div>
                    <h3 class="card-title">Students</h3>
                    <p class="card-text text-muted">Submit your innovative research proposals and track their progress anonymously.</p>
                    <a asp-controller="Proposal" asp-action="Create" class="btn btn-primary rounded-pill px-4">Submit Proposal</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 border-top border-primary border-5">
                <div class="card-body">
                    <div class="mb-3 text-success"><i class="bi bi-person-check-fill fs-1"></i></div>
                    <h3 class="card-title">Supervisors</h3>
                    <p class="card-text text-muted">Review anonymized project proposals and select the best matches for your expertise.</p>
                    <a asp-controller="Supervisor" asp-action="Index" class="btn btn-success rounded-pill px-4">Review Portal</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <div class="mb-3 text-danger"><i class="bi bi-shield-lock-fill fs-1"></i></div>
                    <h3 class="card-title">Administrators</h3>
                    <p class="card-text text-muted">Manage system users, oversee the matching process, and generate final reports.</p>
                    <a asp-controller="Admin" asp-action="Index" class="btn btn-danger rounded-pill px-4">Admin Panel</a>
                </div>
            </div>
        </div>
    </div>
</div>