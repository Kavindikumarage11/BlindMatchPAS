@model IEnumerable<BlindMatchPAS.Models.ProjectProposal>

@{
    ViewData["Title"] = "Supervisor Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">Supervisor Review Panel</h2>
        <span class="badge bg-secondary">Total Proposals: @Model.Count()</span>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body bg-light">
            <form asp-controller="Supervisor" asp-action="Index" method="get" class="row g-3">
                <div class="col-md-5">
                    <label class="form-label small fw-bold">Search by Title</label>
                    <input type="text" name="searchString" value="@ViewBag.CurrentSearch" 
                           class="form-control" placeholder="Enter project title..." />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold">Filter by Category</label>
                    <select name="category" class="form-select">
                        <option value="">All Categories</option>
                        @foreach (var cat in ViewBag.Categories)
                        {
                            if (cat == ViewBag.CurrentCategory)
                            {
                                <option value="@cat" selected>@cat</option>
                            }
                            else
                            {
                                <option value="@cat">@cat</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100 shadow-sm">
                        <i class="bi bi-funnel-fill"></i> Apply Filters
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle bg-white mb-0">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Project Title</th>
                    <th>Category</th>
                    <th>Status</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">No proposals found matching your criteria.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">#@item.Id</td>
                        <td>@item.Title</td>
                        <td><span class="badge rounded-pill bg-info text-dark">@item.Category</span></td>
                        <td>
                            @if (item.IsMatched)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Matched</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Pending</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary px-3">
                                Review Details
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>