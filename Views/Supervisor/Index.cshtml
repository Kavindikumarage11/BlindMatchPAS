@model IEnumerable<BlindMatchPAS.Models.ProjectProposal>

@{
    ViewData["Title"] = "Supervisor Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary">Supervisor Review Panel</h2>
            <p class="text-muted">Manage, filter, and review research proposals for matching.</p>
        </div>
        <span class="badge bg-dark p-2 px-3 shadow-sm">Total Proposals: @Model.Count()</span>
    </div>

    <div class="card shadow-sm border-0 mb-4 rounded-3">
        <div class="card-body bg-light p-4">
            <form asp-controller="Supervisor" asp-action="Index" method="get" class="row g-3">
                <div class="col-md-5">
                    <label class="form-label small fw-bold text-secondary">Search by Title</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchString" value="@ViewBag.CurrentSearch" 
                               class="form-control border-start-0" placeholder="Enter project title..." />
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-secondary">Filter by Category</label>
                    <select name="category" class="form-select">
                        <option value="">All Categories</option>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var cat in ViewBag.Categories)
                            {
                                if (cat == ViewBag.CurrentCategory)
                                {
                                    <option value="@cat" selected>@cat</option>
                                }
                                else
                                {
                                    <option value="@cat">@cat</option>
                                }
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100 shadow-sm fw-bold">
                        <i class="bi bi-funnel-fill me-2"></i> Apply Filters
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded-3">
        <table class="table table-hover align-middle bg-white mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">ID</th>
                    <th>Project Title</th>
                    <th>Category</th>
                    <th>Status</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="bi bi-folder-x display-4 d-block mb-2"></i>
                            No proposals found matching your criteria.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-secondary">#@item.Id</td>
                            <td class="fw-semibold">@item.Title</td>
                            <td>
                                <span class="badge rounded-pill bg-info text-dark px-3">@item.Category</span>
                            </td>
                            <td>
                                @if (item.IsMatched)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success px-3">
                                        <i class="bi bi-check-circle-fill me-1"></i> Matched
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-subtle text-warning-emphasis border border-warning px-3">
                                        <i class="bi bi-clock-fill me-1"></i> Pending
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" 
                                   class="btn btn-sm btn-outline-primary px-4 rounded-pill shadow-sm">
                                    <i class="bi bi-eye-fill me-1"></i> Review Details
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>