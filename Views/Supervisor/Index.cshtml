@model IEnumerable<BlindMatchPAS.Models.ProjectProposal>

<div class="container mt-4">
    <h2>Supervisor Dashboard: Blind Review</h2>
    <p class="text-muted">Review proposals based on content only (Student identities are hidden).</p>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title text-primary">@item.Title</h5>
                        <p class="card-text"><strong>Abstract:</strong> @item.Abstract</p>
                        <p class="card-text"><strong>Tech Stack:</strong> <span class="badge bg-info text-dark">@item.TechStack</span></p>
                        
                        <div class="d-flex justify-content-between align-items-center">
                            @if (!item.IsMatched)
                            {
                                <form asp-action="Approve" asp-route-id="@item.Id" method="post">
                                    <button type="submit" class="btn btn-success btn-sm">Interested / Approve</button>
                                </form>
                            }
                            else
                            {
                                <span class="badge bg-success">Matched & Approved</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>