@model IEnumerable<BlindMatchPAS.Models.ProjectProposal>

@foreach (var item in Model)
{
    <div class="card-body">
        <h5 class="card-title text-primary">@item.Title</h5>
        <p class="card-text"><strong>Abstract:</strong> @item.Abstract</p>
        <p class="card-text"><strong>Tech Stack:</strong> <span class="badge bg-info text-dark">@item.TechStack</span></p>

        <div class="d-flex justify-content-between align-items-center">
            @if (!item.IsMatched)
            {
                <form asp-action="ApproveProposal" asp-controller="Supervisor" asp-route-id="@item.Id" method="post">
                    <button type="submit" class="btn btn-success btn-sm">Confirm Match / Approve</button>
                </form>
            }
            else
            {
                <div class="text-center">
                    <span class="badge bg-success">Matched & Approved</span>
                    <p class="small text-muted mt-1">Identity Revealed!</p>
                </div>
            }
        </div>
    </div>
}