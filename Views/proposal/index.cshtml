@model IEnumerable<BlindMatchPAS.Models.ProjectProposal>

@{
    ViewData["Title"] = "My Proposals";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Submitted Proposals</h2>
        <a asp-action="Create" class="btn btn-primary">Submit New Proposal</a>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">@TempData["Message"]</div>
    }

    <table class="table table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Project Title</th>
                <th>Technologies</th>
                <th>Status</th>
                <th>Supervisor Details</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>
                        <span class="badge bg-info text-dark">@item.TechStack</span>
                    </td>
                    <td>
                        @if (item.IsMatched)
                        {
                            <span class="badge bg-success">Matched</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                    </td>
                    <td>
                        @if (item.IsMatched && !item.IsIdentityRevealed)
                        {
                            <form asp-action="RevealSupervisor" asp-route-id="@item.Id" method="post">
                                <button type="submit" class="btn btn-sm btn-outline-primary">Reveal Supervisor</button>
                            </form>
                        }
                        else if (item.IsIdentityRevealed)
                        {
                            <strong class="text-success">Identity Revealed ✅</strong>
                        }
                        else
                        {
                            <span class="text-muted small">Hidden until matched</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>