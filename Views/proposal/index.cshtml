@model IEnumerable<BlindMatchPAS.Models.ProjectProposal>

@{
    ViewData["Title"] = "My Proposals";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h2 class="fw-bold text-dark">My Submitted Proposals</h2>
            <p class="text-muted">Track the status of your research proposals and reveal matched supervisors.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
            <i class="bi bi-plus-circle me-2"></i>Submit New Proposal
        </a>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Project Title</th>
                        <th>Technologies</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Supervisor Match</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <span class="fw-semibold text-primary">@item.Title</span>
                            </td>
                            <td>
                                <span class="badge rounded-pill bg-info text-dark px-3">@item.TechStack</span>
                            </td>
                            <td class="text-center">
                                @if (item.IsMatched)
                                {
                                    <span class="badge bg-success shadow-sm p-2 px-3">
                                        <i class="bi bi-check-all me-1"></i>Matched
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark shadow-sm p-2 px-3">
                                        <i class="bi bi-clock-history me-1"></i>Pending
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.IsMatched && !item.IsIdentityRevealed)
                                {
                                    <form asp-action="RevealSupervisor" asp-route-id="@item.Id" method="post">
                                        <button type="submit" class="btn btn-sm btn-outline-primary rounded-pill px-4 shadow-sm">
                                            <i class="bi bi-eye-fill me-1"></i>Reveal Identity
                                        </button>
                                    </form>
                                }
                                else if (item.IsIdentityRevealed)
                                {
                                    <div class="d-flex flex-column align-items-center">
                                        <span class="text-success fw-bold">
                                            <i class="bi bi-person-check-fill me-1"></i>Identity Revealed
                                        </span>
                                        </div>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic small">Waiting for match...</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>