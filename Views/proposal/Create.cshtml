@model BlindMatchPAS.Models.ProjectProposal

@{
    ViewData["Title"] = "Submit Project Proposal";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white p-3">
                    <h4 class="mb-0"><i class="bi bi-file-earmark-plus me-2"></i>Submit Your Project Proposal</h4>
                </div>
                <div class="card-body p-4">
                    
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Title" class="form-label fw-bold">Project Title</label>
                            <input asp-for="Title" class="form-control" placeholder="e.g. Web application for Coffee Shop" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Category" class="form-label fw-bold">Project Category</label>
                            <select asp-for="Category" class="form-select">
                                <option value="">-- Select a Category --</option>
                                <option value="Web Application">Web Application</option>
                                <option value="Mobile Application">Mobile Application</option>
                                <option value="Desktop Application">Desktop Application</option>
                                <option value="AI/Machine Learning">AI/Machine Learning</option>
                            </select>
                            <span asp-validation-for="Category" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Abstract" class="form-label fw-bold">Abstract / Description</label>
                            <textarea asp-for="Abstract" class="form-control" rows="5" placeholder="Briefly explain your project goals..."></textarea>
                            <span asp-validation-for="Abstract" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="TechStack" class="form-label fw-bold">Technology Stack</label>
                            <input asp-for="TechStack" class="form-control" placeholder="e.g. HTML, CSS, Bootstrap, C#, ASP.NET Core" />
                            <span asp-validation-for="TechStack" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                <i class="bi bi-send-fill me-2"></i>Submit Proposal
                            </button>
                            <a asp-action="Index" class="btn btn-link text-secondary">Back to My Proposals</a>
                        </div>
                    </form>
                    
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}